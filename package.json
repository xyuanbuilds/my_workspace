{
  "name": "ocr-skill",
  "version": "1.0.0",
  "description": "Claude Code Skill for OCR - supports local files and clipboard",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && cp dist/cli.js dist/clipboard.js dist/ocr.js .claude/skills/ocr/scripts/",
    "dev": "tsc --watch",
    "ocr": "node dist/cli.js",
    "mcp": "node dist/mcp-server.js"
  },
  "bin": {
    "ocr": "dist/cli.js"
  },
  "keywords": [
    "claude-code",
    "skill",
    "ocr",
    "tesseract"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "tesseract.js": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  }
}
