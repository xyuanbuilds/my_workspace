{
  "name": "my-skills",
  "version": "1.0.0",
  "description": "Claude Code Skills collection",
  "type": "module",
  "scripts": {
    "build": "npm run build:ocr && npm run sync",
    "build:ocr": "tsc -p skills/ocr/tsconfig.json",
    "dev:ocr": "tsc -p skills/ocr/tsconfig.json --watch",
    "sync": "node scripts/sync-skills.js",
    "sync:ocr": "node scripts/sync-skills.js ocr",
    "ocr:cli": "node skills/ocr/dist/cli.js",
    "ocr:mcp": "node skills/ocr/dist/mcp-server.js"
  },
  "keywords": [
    "claude-code",
    "skills"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "canvas": "^3.2.1",
    "tesseract.js": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  }
}
